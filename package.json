{
  "name": "fp-ts-exercises",
  "version": "2.0.0",
  "description": "Interactive exercises to learn functional programming in TypeScript using the fp-ts library",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "exercise": "node scripts/exercise.js",
    "solution": "cross-env SOLUTION=true node scripts/exercise.js",
    "generate:exercises": "node scripts/generate-playground-data.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.{js,ts}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.{js,ts}\"",
    "dev": "npm run exercise",
    "clean": "rm -rf dist node_modules/.cache",
    "prepare": "husky"
  },
  "keywords": [
    "fp-ts",
    "functional-programming",
    "typescript",
    "exercises",
    "learning",
    "tutorial"
  ],
  "author": "David Royle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Spikedar/fp-ts-exercises.git"
  },
  "bugs": {
    "url": "https://github.com/Spikedar/fp-ts-exercises/issues"
  },
  "homepage": "https://github.com/Spikedar/fp-ts-exercises#readme",
  "dependencies": {
    "fp-ts": "^2.16.10"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vitest/ui": "^3.2.4",
    "chokidar": "^3.6.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
